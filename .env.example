# Server
PORT=3001
CLIENT_ORIGIN=http://localhost:5173

# Ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2
# OLLAMA_TEMPERATURE=0.1
# OLLAMA_CTX=2048

# Logging (debug | info | warn | error | silent — default: info)
# LOG_LEVEL=info

# Config endpoint auth (optional)
# When set, POST /api/config/llm and /api/config/feeds require X-Config-Key header
# CONFIG_SECRET=your_config_secret_here

# SQLite database path (optional — defaults to ./intelligence.db in cwd)
# Useful for Docker deployments where the DB lives inside a named volume
# DB_PATH=/app/data/intelligence.db

# AIS Ship Tracking (optional)
# Free API key from https://aisstream.io — leave blank to disable the ships layer
# AISSTREAM_API_KEY=your_key_here

# Webhook Event Ingestion (optional)
# Set a secret key to enable POST /api/events/webhook for external event push.
# Send X-Webhook-Key: <your_secret> in the request header.
# WEBHOOK_SECRET=your_secret_here

# Conflict Front Layer (optional)
# URL of a GeoJSON FeatureCollection with conflict front lines / controlled territory.
# Features use a `control` property: "frontline" | "contested" | "russia" | "ukraine"
# Refreshed every 24 hours. Falls back to demo data (approximate Ukraine 2024) if unset.
# CONFLICT_GEOJSON_URL=https://example.com/conflict_fronts.geojson
