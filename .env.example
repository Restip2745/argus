# Server
PORT=3001
CLIENT_ORIGIN=http://localhost:5173

# Ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# AIS Ship Tracking (optional)
# Free API key from https://aisstream.io — leave blank to disable the ships layer
# AISSTREAM_API_KEY=your_key_here

# Conflict Front Layer (optional)
# URL of a GeoJSON FeatureCollection with conflict front lines / controlled territory.
# Features use a `control` property: "frontline" | "contested" | "russia" | "ukraine"
# Refreshed every 24 hours. Falls back to demo data (approximate Ukraine 2024) if unset.
# CONFLICT_GEOJSON_URL=https://example.com/conflict_fronts.geojson
