{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "ARGUS Client (Vite)",
      "runtimeExecutable": "node",
      "runtimeArgs": ["./node_modules/vite/bin/vite.js", "client", "--port", "5173"],
      "port": 5173,
      "autoPort": false
    },
    {
      "name": "ARGUS Server (Express + Socket.io)",
      "runtimeExecutable": "node",
      "runtimeArgs": ["./node_modules/tsx/dist/cli.mjs", "watch", "server/src/index.ts"],
      "port": 3001
    }
  ]
}
